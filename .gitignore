# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
dist/
build/
.next/
out/
.turbo/

# Environments (never commit secrets)
.env
.env.local
.env.*.local
!.env.example

# Databases
*.db
*.sqlite

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test coverage
coverage/

# Prisma
packages/db/prisma/migrations/dev.db*

# Expo (mobile)
apps/mobile/.expo/
apps/mobile/web-build/
apps/mobile/ios/build/
apps/mobile/android/build/

# Sensitive customer data — never commit
seeds/excel-master/*.xlsx
seeds/excel-master/*.csv
seeds/dir/*.pdf
!seeds/dir/.gitkeep
!seeds/excel-master/.gitkeep

# Uploaded plan sets / bid docs — never commit
uploads/

# Local AI draft history (file-backed store before Postgres lands).
# Each draft can include the full RFP text the user pasted, which may be
# pre-public bid material.
apps/api/data/
