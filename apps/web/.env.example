# Web app environment variables.
#
# Copy this file to .env.local for local dev:
#     cp .env.example .env.local
#
# On Vercel, set the same vars in the Project's "Environment Variables"
# settings (Production + Preview + Development).

# Where the API server lives. Local dev runs on :4000; production
# Vercel can either point at the same Vercel project (if /api routes
# move into the web app) or at a separate API host.
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# Supabase (left blank for now — auth uses the dev-mode email allow-
# list in lib/auth.ts when these are unset).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
