# Copy this to .env and fill in real values. Never commit .env.

# -------- Database --------
# Local development (Docker Compose Postgres)
DATABASE_URL="postgresql://yge:yge_dev_password@localhost:5432/yge_dev?schema=public"

# Production (Supabase) — leave commented locally, set in Vercel dashboard
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# -------- Supabase (auth, storage, realtime) --------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# -------- Anthropic (Plans-to-Estimate, AI features) --------
ANTHROPIC_API_KEY=""

# -------- Auth --------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# -------- API server --------
API_PORT=4000
API_URL="http://localhost:4000"

# -------- Observability (optional in dev) --------
SENTRY_DSN=""

# -------- Feature flags --------
FEATURE_PLANS_TO_ESTIMATE="true"
FEATURE_FORM_FILLER="true"
FEATURE_EMAIL_INTELLIGENCE="false"
